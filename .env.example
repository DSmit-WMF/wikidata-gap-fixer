##############################################
# Root .env for Docker-based development
# Copy this file to `.env` and fill in values
# before running `docker compose up`.
#
# These values are injected into the backend
# container via `docker-compose.yml`.
##############################################

# Shared secret for session cookies (backend)
SESSION_SECRET=your-session-secret

# OpenAI configuration
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5-nano
OPENAI_MAX_OUTPUT_TOKENS=1024

# Wikidata OAuth owner-only consumer
WIKIDATA_OAUTH_CLIENT_ID=your-wikidata-oauth-client-id
WIKIDATA_OAUTH_ACCESS_TOKEN=your-wikidata-oauth-access-token

# Feature flags
LLM_ENABLED=true
SUGGESTION_TYPE_NL_NOUN_PLURAL=true
SUGGESTION_TYPE_NL_VERB_FORMS=true
SUGGESTION_TYPE_NL_ADJECTIVE_FORMS=true
SUGGESTION_TYPE_ITEM_LABEL_NL_FROM_EN=true

# Rule thresholds
MIN_RULE_CONFIDENCE=0.7
MAX_SUGGESTIONS_PER_BATCH=200


# Pipeline test mode (optional)
# When enabled, the backend only processes a small number
# of candidates per suggestion type (e.g. 1 noun, 1 verb, 1 adjective).
# PIPELINE_TEST_MODE=true
# PIPELINE_TEST_LIMIT=1

