DATABASE_URL=postgres://wikidata_gap_fixer:secret@localhost:5432/wikidata_gap_fixer
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5-nano
OPENAI_MAX_OUTPUT_TOKENS=1024

WIKIDATA_OAUTH_CLIENT_ID=your-oauth-client-id
WIKIDATA_OAUTH_ACCESS_TOKEN=your-owner-only-access-token

SESSION_SECRET=change-me-to-a-random-secret

# Feature flags
LLM_ENABLED=true
SUGGESTION_TYPE_NL_NOUN_PLURAL=true
SUGGESTION_TYPE_NL_VERB_FORMS=true
SUGGESTION_TYPE_NL_ADJECTIVE_FORMS=true
SUGGESTION_TYPE_ITEM_LABEL_NL_FROM_EN=true

# Rule thresholds
MIN_RULE_CONFIDENCE=0.7
MAX_SUGGESTIONS_PER_BATCH=200

# Test mode: only process this many candidates per type (e.g. 1 noun, 1 verb, 1 adjective)
# Set PIPELINE_TEST_MODE=true to enable; use PIPELINE_TEST_LIMIT to override (default 1)
# PIPELINE_TEST_MODE=false
# PIPELINE_TEST_LIMIT=1

PORT=3001
FRONTEND_URL=http://localhost:3000
